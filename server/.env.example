# ====== 必填 ======
# 大模型接口（OpenAI 兼容）。本地不配也能起后端，但创建任务时会失败。
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
# 思考模式（仅 deepseek-v4-* 有效）。默认关闭以保流式体验；想要更高质量可设 true。
# LLM_THINKING_ENABLED=false

# ====== 公网部署才需要 ======
# 留空 = 不校验 Bearer Token（仅适合本地）；公网请用 `openssl rand -hex 32` 生成
API_TOKEN=
# 留空 = 默认允许 http://localhost:5173 / http://127.0.0.1:5173
APP_CORS_ORIGINS=

# ====== 可选：私享视频 / 字幕需登录态时填 ======
# 浏览器登录 B 站后从 cookie 复制；可只填 SESSDATA
BILI_SESSDATA=
# BILI_BUVID3=
# BILI_BILI_JCT=

# ====== 可选：本地 ASR 转写（无字幕的视频才会用到） ======
# 默认 sensevoice（funasr CPU，跨平台）。Mac 用户建议先 `uv sync --extra asr-mlx`
# 再改成下面 auto / sensevoice-mlx / parakeet-mlx 之一（M 系列 GPU/ANE 加速 15-30×）。
# 完整对比见 README「本地 ASR 转写」章节。
# ASR_MODEL=auto

# ====== 可选：邮件发送 ======
# 默认关闭；启用前请同时配齐 webhook 与收件人
EMAIL_ENABLED=false
# EMAIL_WEBHOOK_URL=https://your-mail-worker.example.com
# EMAIL_WEBHOOK_TOKEN=
# EMAIL_DEFAULT_RECIPIENT=you@example.com

# ====== 公网部署防滥用 ======
# 视频时长上限（秒）。超长视频拖死 ASR/LLM 槽位，且总结质量差。默认 2.5 小时。
# MAX_VIDEO_DURATION_SECONDS=9000
# 在飞任务（PENDING + RUNNING）总数上限。超出返回 503，避免 PENDING 队列无限堆积。
# MAX_INFLIGHT_JOBS=20
# /v1/llm/models 与任务里 llm_base_url 的 host 白名单（防 SSRF）。留空 = 不限制（仅本地）。
# LLM_BASE_URL_ALLOWED_HOSTS=api.deepseek.com,api.moonshot.cn,open.bigmodel.cn,generativelanguage.googleapis.com,api.openai.com,api.anthropic.com,api.x.ai

# ====== 高级 / 调优 ======
# 完整配置参考 README「配置参考」一节；以下变量都有合理默认，多数情况无需调整：
# APP_LOG_LEVEL / ASR_MODEL / ASR_DEVICE / SENSEVOICE_MODEL_DIR /
# LLM_TIMEOUT_SECONDS / LLM_MAX_RETRIES / LLM_TEMPERATURE / LLM_SEGMENT_CONCURRENCY /
# SUMMARY_LANGUAGE / EMAIL_SUBJECT_TEMPLATE /
# AUDIO_STORAGE_DIR / SUMMARY_STORAGE_DIR / DB_PATH /
# AUDIO_RETENTION_DAYS / JOB_RETENTION_DAYS / MAX_CONCURRENT_JOBS / MAX_CONCURRENT_SUMMARIES /
# CLEANUP_INTERVAL_SECONDS / WAL_CHECKPOINT_INTERVAL_HOURS / DB_VACUUM_INTERVAL_DAYS /
# STALE_RUNNING_FAIL_HOURS / ORPHAN_FILE_RETENTION_DAYS
